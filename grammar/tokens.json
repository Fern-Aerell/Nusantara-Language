[
 {
  "name": "WHITESPACE",
  "rule": {
   "pattern": "[ \\t\\r\\f]+",
   "case_sensitive": true,
   "dot_all": false,
   "multiline": false,
   "unicode": false
  },
  "skip": true
 },
 {
  "name": "NEWLINE",
  "rule": {
   "pattern": "\\n",
   "case_sensitive": true,
   "dot_all": false,
   "multiline": false,
   "unicode": false
  },
  "skip": true
 },
 {
  "name": "KOMENTAR_SATU_BARIS",
  "rule": {
   "pattern": "//.*",
   "case_sensitive": true,
   "dot_all": false,
   "multiline": false,
   "unicode": false
  },
  "skip": true
 },
 {
  "name": "KOMENTAR_DUA_BARIS",
  "rule": {
   "pattern": "/\\\\*.*?\\\\*/",
   "case_sensitive": true,
   "dot_all": true,
   "multiline": true,
   "unicode": false
  },
  "skip": true
 },
 {
  "name": "TIPE_DATA_BILANGAN_BULAT",
  "rule": {
   "pattern": "bilangan bulat",
   "case_sensitive": true,
   "dot_all": false,
   "multiline": false,
   "unicode": false
  },
  "skip": false
 },
 {
  "name": "TIPE_DATA_BILANGAN_DESIMAL",
  "rule": {
   "pattern": "bilangan desimal",
   "case_sensitive": true,
   "dot_all": false,
   "multiline": false,
   "unicode": false
  },
  "skip": false
 },
 {
  "name": "TIPE_DATA_KARAKTER",
  "rule": {
   "pattern": "karakter",
   "case_sensitive": true,
   "dot_all": false,
   "multiline": false,
   "unicode": false
  },
  "skip": false
 },
 {
  "name": "TIPE_DATA_KALIMAT",
  "rule": {
   "pattern": "kalimat",
   "case_sensitive": true,
   "dot_all": false,
   "multiline": false,
   "unicode": false
  },
  "skip": false
 },
 {
  "name": "TIPE_DATA_BOOLEAN",
  "rule": {
   "pattern": "bool",
   "case_sensitive": true,
   "dot_all": false,
   "multiline": false,
   "unicode": false
  },
  "skip": false
 },
 {
  "name": "NILAI_BILANGAN_BULAT",
  "rule": {
   "pattern": "-?[0-9]+",
   "case_sensitive": true,
   "dot_all": false,
   "multiline": false,
   "unicode": false
  },
  "skip": false
 },
 {
  "name": "NILAI_BILANGAN_DESIMAL",
  "rule": {
   "pattern": "-?[0-9]+,[0-9]+",
   "case_sensitive": true,
   "dot_all": false,
   "multiline": false,
   "unicode": false
  },
  "skip": false
 },
 {
  "name": "NILAI_KARAKTER",
  "rule": {
   "pattern": "(\\\".\\\")|('.')",
   "case_sensitive": true,
   "dot_all": false,
   "multiline": false,
   "unicode": false
  },
  "skip": false
 },
 {
  "name": "NILAI_KALIMAT",
  "rule": {
   "pattern": "(\\\".*?\\\")|('.*?')",
   "case_sensitive": true,
   "dot_all": false,
   "multiline": false,
   "unicode": false
  },
  "skip": false
 },
 {
  "name": "NILAI_BOOLEAN",
  "rule": {
   "pattern": "benar | salah",
   "case_sensitive": true,
   "dot_all": false,
   "multiline": false,
   "unicode": false
  },
  "skip": false
 },
 {
  "name": "SAMA_DENGAN",
  "rule": {
   "pattern": "=",
   "case_sensitive": true,
   "dot_all": false,
   "multiline": false,
   "unicode": false
  },
  "skip": false
 },
 {
  "name": "TITIK_KOMA",
  "rule": {
   "pattern": ";",
   "case_sensitive": true,
   "dot_all": false,
   "multiline": false,
   "unicode": false
  },
  "skip": false
 },
 {
  "name": "KOMA",
  "rule": {
   "pattern": ",",
   "case_sensitive": true,
   "dot_all": false,
   "multiline": false,
   "unicode": false
  },
  "skip": false
 },
 {
  "name": "IDENTIFIKASI",
  "rule": {
   "pattern": "[a-zA-Z_]+[a-zA-Z0-9_]*",
   "case_sensitive": true,
   "dot_all": false,
   "multiline": false,
   "unicode": false
  },
  "skip": false
 }
]