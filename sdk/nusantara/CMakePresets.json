{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 27,
        "patch": 4
    },
    "configurePresets": [
        {
            "name": "debug-windows",
            "generator": "Ninja",
            "binaryDir": "build",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "true"
            }
        },
        {
            "name": "release-windows",
            "generator": "Ninja",
            "binaryDir": "build",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "true",
                "CMAKE_CXX_FLAGS": "-O3 -ffast-math -flto -march=native -mtune=native -msse2 -mavx -fstack-protector"
            }
        },
				{
            "name": "debug-termux",
            "generator": "Ninja",
            "binaryDir": "build",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "clang++-17",
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "true"
            }
        },
        {
            "name": "release-termux",
            "generator": "Ninja",
            "binaryDir": "build",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "clang++-17",
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "true",
								"CMAKE_CXX_FLAGS": "-Ofast -ffast-math -flto -march=native -mtune=native -fstack-protector -g -fsanitize=undefined -fPIE"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug-windows",
            "configurePreset": "debug-windows"
        },
        {
            "name": "release-windows",
            "configurePreset": "release-windows"
        },
				{
            "name": "debug-termux",
            "configurePreset": "debug-termux"
        },
        {
            "name": "release-termux",
            "configurePreset": "release-termux"
        }
    ]
}
